PORT=5000
MONGODB_URI=mongodb://localhost:27017/heerme
# 6-digit dashboard PIN (required for /api/auth/login)
HEERME_PIN=000000
# At least 16 characters; used to sign session tokens
JWT_SECRET=change-this-to-a-long-random-string
# Comma-separated browser origins allowed to call the API (e.g. Vercel URL).
# Leave empty only for local/dev (reflects any Origin). Production should set this.
# CORS_ORIGIN=https://heer-me.vercel.app
